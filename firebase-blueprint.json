        "uid": { "type": "string", "description": "Firebase Auth UID of the student" },
        "password": { "type": "string", "description": "Login password" },
        "customFields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "value": { "type": "string" },
