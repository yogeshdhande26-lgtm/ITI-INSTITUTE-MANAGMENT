{
  "entities": {
    "Instructor": {
      "title": "Instructor",
      "description": "An ITI Instructor",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the instructor" },
        "email": { "type": "string", "format": "email", "description": "Official email address" },
        "trade": { "type": "string", "description": "Trade/Department (e.g., Electrician, Fitter)" },
        "qualification": { "type": "string", "description": "Educational qualification" },
        "experience": { "type": "string", "description": "Years of experience" },
        "phone": { "type": "string", "description": "Contact number" },
        "joiningDate": { "type": "string", "format": "date", "description": "Date of joining ITI" },
        "status": { "type": "string", "enum": ["Active", "Inactive"], "description": "Current employment status" },
        "loginId": { "type": "string", "description": "Custom Login ID for the instructor" },
        "password": { "type": "string", "description": "Login password" },
        "uid": { "type": "string", "description": "Firebase Auth UID of the instructor (if they have login access)" },
        "role": { "type": "string", "enum": ["admin", "instructor"], "description": "Role in the system" },
        "customFields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "value": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "textarea"] }
            }
          }
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "url": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "email", "trade", "status"]
    },
    "User": {
      "title": "User",
      "description": "System user (Admin or Instructor)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "instructor", "student"] },
        "displayName": { "type": "string" },
        "enabledFeatures": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of feature IDs enabled for this user"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
